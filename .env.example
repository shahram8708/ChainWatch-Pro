# Flask Core
FLASK_ENV=development
FLASK_APP=run.py
USE_REDIS=False
CELERY_ENABLED=False
DEV_DATABASE_URL=sqlite:///instance/chainwatchpro_dev.sqlite3
AUTO_CREATE_DB=True
POSTGRES_MAINTENANCE_DB=postgres
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# Database (production)
DATABASE_URL=postgresql://chainwatch_user:yourpassword@localhost:5432/chainwatchpro

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Email (SMTP)
MAIL_SERVER=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_password
MAIL_DEFAULT_SENDER=noreply@chainwatchpro.com

# Razorpay (Indian Rupees)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Optional recurring plan ids. Leave blank to use one-time Order checkout fallback.
RAZORPAY_PLAN_STARTER_MONTHLY=
RAZORPAY_PLAN_STARTER_ANNUAL=
RAZORPAY_PLAN_PROFESSIONAL_MONTHLY=
RAZORPAY_PLAN_PROFESSIONAL_ANNUAL=
# Enterprise is handled via sales workflow by default.
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=
RAZORPAY_PLAN_ENTERPRISE_ANNUAL=

# Google Gemini AI
GEMINI_API_KEY=your_google_gemini_api_key

# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Encryption (carrier credentials)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# SuperAdmin Configuration (CHANGE THESE IN PRODUCTION)
SUPERADMIN_URL_PREFIX=/sa-panel
SUPERADMIN_EMAIL=superadmin@chainwatchpro.internal
SUPERADMIN_PASSWORD=ChainWatch@SuperAdmin2026!
SUPERADMIN_SESSION_TIMEOUT=30
